# =====================================================
# FIFA 2026 API — Backend env vars
# =====================================================
# Copie este arquivo para .env e ajuste os valores.
# .env NÃO deve ser commitado.
# =====================================================

# ----------------------------------------------------
# Banco de Dados (SQL Server / Azure SQL)
# ----------------------------------------------------
# Cenário VM:    IP privado da VM-DB (mesmo VNet/subnet)
# Cenário WebApp: <server>.database.windows.net (Azure SQL)
DB_SERVER=10.20.1.4
DB_PORT=1433
DB_USER=fifa2026_db
DB_PASSWORD=trocar_essa_senha
DB_NAME=FIFA2026Tickets

# ----------------------------------------------------
# HTTP
# ----------------------------------------------------
# Porta do Express. Em iisnode (VM/Web App Windows) PORT é injetada
# automaticamente como named pipe — não precisa setar.
PORT=3001

# Bind do Express. 0.0.0.0 aceita conexões de outras VMs do VNet
# (necessário no cenário de 3 VMs com backend privado).
# Em iisnode esta variável é ignorada.
HOST=0.0.0.0

# ----------------------------------------------------
# JWT
# ----------------------------------------------------
JWT_SECRET=trocar_por_uma_string_longa_aleatoria
JWT_EXPIRES_IN=7d

# ----------------------------------------------------
# CORS
# ----------------------------------------------------
# Lista separada por vírgula de origens permitidas.
# Quando o frontend usa o proxy reverso do IIS (/api -> backend),
# CORS nem é exercitado — então pode listar só a origem de dev.
#
# Exemplos:
#   - Dev local:        http://localhost:5173,http://localhost:8080
#   - VM (front):       http://<ip-publico-front>
#   - Web App (front):  https://fifa2026-web.azurewebsites.net
#   - Liberar tudo:     *
FRONTEND_URL=http://localhost:5173,http://localhost:8080
