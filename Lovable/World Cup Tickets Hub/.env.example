# =====================================================
# FIFA 2026 Web — Frontend env vars
# =====================================================
# Copie este arquivo para .env e ajuste os valores.
# .env NÃO deve ser commitado.
# =====================================================

# ----------------------------------------------------
# Dev (npm run dev) — Vite proxy
# ----------------------------------------------------
# URL do backend usada pelo proxy de dev em vite.config.ts.
# Default: http://localhost:3001
VITE_DEV_BACKEND_URL=http://localhost:3001

# ----------------------------------------------------
# Build de produção (npm run build) — IIS web.config
# ----------------------------------------------------
# URL do backend que o web.config vai usar como destino do
# proxy reverso em /api/*. Substituída no dist/web.config
# pelo script scripts/set-backend-url.mjs (postbuild).
#
# Exemplos por cenário:
#   - Dev local:                http://localhost:3001
#   - VM (IP privado backend):  http://10.20.1.5:3001
#   - Azure Web App backend:    https://fifa2026-back.azurewebsites.net
BACKEND_URL=http://localhost:3001

# ----------------------------------------------------
# Override opcional: API_URL absoluta no cliente
# ----------------------------------------------------
# Em geral NÃO setar — o frontend usa "/api" e deixa o proxy
# do IIS/Vite resolver. Setar somente se precisar bypassar
# o proxy (não recomendado: quebra o requisito de backend
# privado e exige CORS aberto).
# VITE_API_URL=
